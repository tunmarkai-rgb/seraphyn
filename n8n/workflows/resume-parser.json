    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const base = $('Select Nurse Profile').first().json;\nconst source = $input.first().json;\nconst rawText = source.text || source.data || source.content || source.extractedText || (Array.isArray(source.pages) ? source.pages.map((page) => page.text || page.content || '').join('\\n\\n') : '') || '';\nconst normalizedText = String(rawText).replace(/\\u0000/g, ' ').replace(/\\s+/g, ' ').trim();\nconst trimmedResumeText = normalizedText.slice(0, 18000);\n\nreturn [{\n  json: {\n    ...base,\n    extractedTextLength: normalizedText.length,\n    trimmedResumeText\n  }\n}];"
      },
      "id": "code-prepare-prompt",
      "name": "Prepare Resume Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2720,
        320
      ]
