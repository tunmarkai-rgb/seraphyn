    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/responses",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'gpt-4.1-mini', input: [ { role: 'system', content: [ { type: 'input_text', text: 'You extract structured nurse resume data for Seraphyn. Return JSON only. Use null when a value is not explicit. certifications must be an array of strings. years_experience must be an integer when clearly inferable. Do not invent license numbers, specialties, states, or dates.' } ] }, { role: 'user', content: [ { type: 'input_text', text: `Existing nurse profile context:\\n${JSON.stringify($json.nurseProfile || {}, null, 2)}\\n\\nResume text:\\n${$json.trimmedResumeText}\\n\\nReturn a JSON object with these keys: full_name, first_name, last_name, email, phone, specialty, license_number, license_state, years_experience, availability, shift_preference, bio, certifications, skills, summary, confidence_notes.` } ] } ] }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "http-openai-parse",
      "name": "OpenAI Resume Parse",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2960,
        320
      ],
      "credentials": {
        "openAiApi": {
          "id": "qqPI7KpcC1ZsxOYR",
          "name": "Seraphyn OpenAI API"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const base = $('Prepare Resume Prompt').first().json;\nconst payload = $input.first().json;\n\nconst maybeText = payload.output_text\n  || payload.output?.map((entry) => (entry.content || []).map((part) => part.text || '').join('\\n')).join('\\n')\n  || payload.choices?.[0]?.message?.content\n  || '';\n\nconst cleaned = String(maybeText)\n  .replace(/^```json\\s*/i, '')\n  .replace(/^```/i, '')\n  .replace(/```$/i, '')\n  .trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(cleaned);\n} catch (error) {\n  parsed = {\n    summary: null,\n    confidence_notes: `Failed to parse OpenAI JSON: ${error.message}`\n  };\n}\n\nconst profile = base.nurseProfile || {};\nconst asArray = (value) => Array.isArray(value) ? value.filter(Boolean) : [];\nconst existingCerts = asArray(profile.certifications);\nconst parsedCerts = asArray(parsed.certifications);\n\nconst updatePayload = {\n  ai_parsed_data: {\n    parsed_at: new Date().toISOString(),\n    source: 'n8n.resume_parser',\n    file_name: base.fileName,\n    file_extension: base.extension,\n    public_resume_url: base.publicResumeUrl,\n    text_length: base.extractedTextLength,\n    model: 'gpt-4.1-mini',\n    parsed\n  }\n};\n\nif (!profile.first_name && parsed.first_name) updatePayload.first_name = parsed.first_name;\nif (!profile.last_name && parsed.last_name) updatePayload.last_name = parsed.last_name;\nif (!profile.specialty && parsed.specialty) updatePayload.specialty = parsed.specialty;\nif (!profile.license_number && parsed.license_number) updatePayload.license_number = parsed.license_number;\nif (!profile.license_state && parsed.license_state) updatePayload.license_state = parsed.license_state;\nif (!profile.years_experience && Number.isInteger(parsed.years_experience)) updatePayload.years_experience = parsed.years_experience;\nif (!profile.availability && parsed.availability) updatePayload.availability = parsed.availability;\nif (!profile.shift_preference && parsed.shift_preference) updatePayload.shift_preference = parsed.shift_preference;\nif (!profile.bio && parsed.bio) updatePayload.bio = parsed.bio;\nif (!existingCerts.length && parsedCerts.length) updatePayload.certifications = parsedCerts;\n\nreturn [{\n  json: {\n    ...base,\n    parsedResume: parsed,\n    updatePayload\n  }\n}];"
      },
