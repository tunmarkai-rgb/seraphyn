    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const source = $input.first().json;\nconst body = source.body ?? source;\nconst record = body.record ?? body.new ?? body.object ?? body;\nconst headers = source.headers ?? {};\nconst supabaseUrl = 'https://rchydpjwyfpxuexnipwk.supabase.co';\nconst bucket = record.bucket_id || record.bucket || body.bucket_id || body.bucket || '';\nconst objectPath = record.name || record.path || record.object_path || body.name || body.path || '';\nconst eventType = body.type || body.event || body.eventType || record.eventType || headers['x-supabase-event'] || headers['X-Supabase-Event'] || 'unknown';\nconst normalizedEventType = String(eventType).toUpperCase();\nconst fileName = objectPath.split('/').pop() || '';\nconst extension = (fileName.includes('.') ? fileName.split('.').pop() : '').toLowerCase();\nconst encodedPath = objectPath.split('/').map(encodeURIComponent).join('/');\nconst publicResumeUrl = bucket && objectPath ? `${supabaseUrl}/storage/v1/object/public/${bucket}/${encodedPath}` : '';\nconst bucketPath = bucket && objectPath ? `${bucket}/${objectPath}` : objectPath;\nconst candidates = [publicResumeUrl, bucketPath, objectPath].filter(Boolean);\nconst orFilter = candidates.map((value) => `resume_url.eq.${encodeURIComponent(value)}`).join(',');\nconst lookupUrl = `${supabaseUrl}/rest/v1/nurse_profiles?select=id,user_id,first_name,last_name,specialty,license_number,license_state,years_experience,availability,shift_preference,bio,certifications,resume_url&or=(${orFilter})&limit=1`;\nconst shouldProcess = bucket === 'resumes' && ['INSERT', 'UPDATE', 'OBJECT_CREATED', 'STORAGE.OBJECT.CREATED'].includes(normalizedEventType) && ['pdf', 'rtf', 'txt'].includes(extension);\n\nreturn [{\n  json: {\n    supabaseUrl,\n    eventType,\n    bucket,\n    objectPath,\n    bucketPath,\n    fileName,\n    extension,\n    publicResumeUrl,\n    lookupUrl,\n    shouldProcess,\n    supportedExtensions: ['pdf', 'rtf', 'txt'],\n    rawRecord: record\n  }\n}];"
      },
